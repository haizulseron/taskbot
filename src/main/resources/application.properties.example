# Copy this to application.properties and fill in your values.

# Telegram bot settings
bot.username=YOUR_BOT_USERNAME
bot.token=YOUR_BOT_TOKEN

# Anthropic Claude API key (https://console.anthropic.com)
claude.api.key=YOUR_CLAUDE_API_KEY

# OpenAI Whisper API key for voice-to-task (https://platform.openai.com)
# Leave blank to disable voice input
whisper.api.key=YOUR_OPENAI_API_KEY

# App settings
app.timezone=Asia/Singapore
app.morning.summary.time=08:00
app.scheduler.check.interval.seconds=60
app.db.path=/home/telegrambot/projects/taskbot/data/taskbot.db
app.default.stale.days=3

# Notion integration for Quick Notes
notion.api.key=YOUR_NOTION_API_KEY
notion.database.id=YOUR_NOTION_DATABASE_ID

# Google integration (Gmail, Calendar, Drive)
# 1. Go to console.cloud.google.com → create project → enable Gmail, Calendar, Drive APIs
# 2. Create OAuth 2.0 credentials (Desktop app) → download as credentials.json
# 3. Set the path to your credentials.json below
# 4. Leave blank to disable Google features
# 5. After starting the bot, send /authorize to complete the one-time OAuth flow
google.credentials.path=/path/to/credentials.json
google.tokens.path=data/google_tokens
